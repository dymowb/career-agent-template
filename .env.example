# Required — Claude API (all agents). https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Required for job discovery — RapidAPI "JSearch" API.
# https://rapidapi.com → subscribe to jsearch.p.rapidapi.com
RAPIDAPI_KEY=

# Optional — emailed daily digest (leave blank to disable).
# For Gmail, use an App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_TO=you@example.com
